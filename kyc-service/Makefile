.PHONY: run build test test-integration test-all lint tidy

run:
	go run ./cmd/api/...

build:
	go build -o bin/api ./cmd/api/...

test:
	go test -race ./...

lint:
	golangci-lint run ./...

test-integration:
	go test -tags=integration -timeout=5m -v ./test/integration/...

test-all:
	go test -race ./...
	go test -tags=integration -race -timeout=5m ./test/integration/...

tidy:
	go mod tidy
